 "antipatterns": [
  {
   "id": "AP1",
   "name": "Bars for means separation (bars hide distribution)",
   "fix": "show the distribution: dot-on-bar / strip / box",
   "prefer": [
    "S1",
    "S2",
    "S3"
   ],
   "ref": "10.1371/journal.pbio.1002128"
  },
  {
   "id": "AP2",
   "name": "Violin/box for small n",
   "fix": "quartiles unstable at small n; use strip/dot",
   "prefer": [
    "S2",
    "S1"
   ],
   "min_n_for_violin": 20,
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP3",
   "name": "Bidirectional (diverging) scale for unidirectional data",
   "fix": "use a sequential scale; endpoints map to real max/min/zero",
   "prefer_palette": "sequential",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP4",
   "name": "Bar-plot meadow (many bars, multifactor)",
   "fix": "facet/group by the factor of interest",
   "prefer": [
    "M7_small_multiples"
   ],
   "ref": "10.1186/s12870-020-2243-7"
  },
  {
   "id": "AP5",
   "name": "Heatmap without reordering rows/columns",
   "fix": "cluster/reorder to reveal structure",
   "ref": "10.1101/2022.07.04.498697"
  },
  {
   "id": "AP6",
   "name": "Heatmap without checking outliers",
   "fix": "cap the color scale (~95th pct)",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP7",
   "name": "Not checking data range per factor level",
   "fix": "check per-factor range; narrow effects hide on a shared scale",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP8",
   "name": "Network graphs with a single layout",
   "fix": "try multiple layouts",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP9",
   "name": "Confusing position-based vs length-based encodings",
   "fix": "bars must be zero-based (length); dots/box are position-based; no broken-axis bars",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP10",
   "name": "Pie chart",
   "fix": "stacked / side-by-side bars (length beats angle)",
   "prefer": [
    "S24",
    "stacked_bar"
   ],
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP11",
   "name": "Concentric donuts",
   "fix": "unwrap to stacked bars (outer rings exaggerate)",
   "prefer": [
    "stacked_bar"
   ],
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP12",
   "name": "Red/green and rainbow (jet) color scales",
