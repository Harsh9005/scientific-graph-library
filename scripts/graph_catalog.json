 "style_engines": {
  "scienceplots_nature": {
   "apply": "plt.style.use(['science','nature','no-latex'])",
   "figsize_in": [
    3.3,
    2.5
   ],
   "font": "sans-serif 7pt (DejaVu/Arial/Helvetica)",
   "axes_linewidth": 0.5,
   "ticks": "inward, top+right",
   "license": "MIT",
   "install": "pip install SciencePlots",
   "caveat": "base 'science' needs LaTeX; the 'no-latex' overlay removes that dependency"
  },
  "scienceplots_ieee": {
   "apply": "plt.style.use(['science','ieee','no-latex'])",
   "figsize_in": [
    3.3,
    2.5
   ],
   "dpi": 600,
   "note": "B/W-safe line-style cycler (k/r/b/g + -/--/:/-.)",
   "license": "MIT"
  },
  "scienceplots_science": {
   "apply": "plt.style.use(['science','no-latex'])",
   "font": "serif base",
   "license": "MIT",
   "caveat": "drop 'no-latex' only if TeX Live is installed"
  },
  "ultraplot_multipanel": {
   "apply": "import ultraplot as uplt; fig,axs=uplt.subplots(ncols=..,nrows=..,abc=True,share=3)",
   "features": [
    "auto a/b/c panel labels (abc=True)",
    "shared/spanning axes (sharex/y, spanx/y)",
    "figure sizing in mm/cm (refwidth/figwidth units)",
    "unified fig.colorbar/fig.legend"
   ],
   "license": "MIT",
   "install": "pip install ultraplot"
  }
 },
 "stat_methods": {
  "compare_two_groups": {
   "method": "test normality+equal-variance first; t-test if met else Mann-Whitney/Welch; report effect size + 95% CI, not just p",
   "see": "statistics-rigor (A)(C)"
  },
  "compare_multi_groups": {
   "method": "one-way ANOVA + Tukey/Dunnett with multiplicity correction; name the test per panel",
   "see": "statistics-rigor C7"
  },
  "two_factor": {
   "method": "two-way ANOVA (interaction reported)",
   "see": "S7"
  },
  "dose_response": {
   "method": "fit model; report EC50/IC50 with CI + goodness",
   "see": "S12"
  },
  "survival": {
   "method": "Kaplan-Meier + log-rank; never an endpoint bar",
   "see": "S31"
  },
  "agreement_pred_obs": {
   "method": "parity (S13) + Bland-Altman (S14) + %PE / relative-L2 (domain); not bare R\u00b2",
   "see": "S13/S14, domain-conventions"
  },
  "regression": {
   "method": "report R2adj + residual plot + CI band; check heteroscedasticity",
   "see": "statistics-rigor F1"
  },
  "model_selection": {
   "method": "AIC/AICc/BIC and/or cross-validation over ranked candidates; not raw R\u00b2",
   "see": "statistics-rigor F2/F3"
  },
  "dimensionality": {
   "method": "SVD/PCA scree + variance-explained at r + reconstruction error",
   "see": "S43/S44, statistics-rigor F5"
  },
  "dissolution_similarity": {
   "method": "f2 / bootstrap-f2 (90% CI) / Mahalanobis + %RSD, n>=6-12",
   "see": "S29, domain-conventions 0/B"
  },
  "PK_exposure": {
   "method": "geometric mean, log-transform AUC/Cmax, 90% CI; BE = 80-125% of GMR CI",
   "see": "S30/S25, domain-conventions 0/B"
  },
  "classifier_perf": {
   "method": "ROC/PR + confusion/calibration + cross-validation",
   "see": "S35/S36, statistics-rigor F3"
  }
 },
 "decision_rules": [
  {
   "id": "R-bars",
   "when": "intent~compare/magnitude & data~categorical",
   "enforce": "bare bars hide the sample -> use dot-on-bar (S1) or strip (S2); AP1",
   "ref": "AP1"
  },
  {
   "id": "R-violin-n",
   "when": "candidate S3/violin & n<20",
   "enforce": "REJECT violin/box; use S1/S2",
   "ref": "AP2"
  },
  {
   "id": "R-diverging",
   "when": "intent~magnitude/field & quantity unidirectional",
   "enforce": "REJECT diverging/jet/rainbow; sequential viridis/cividis",
   "ref": "AP3/AP12"
  },
  {
   "id": "R-partsofwhole",
   "when": "data~compositional / parts-of-whole",
   "enforce": "REJECT pie/donut; stacked or side-by-side bar (S24)",
   "ref": "AP10/AP11"
  },
  {
   "id": "R-heatmap",
   "when": "candidate S17/S40 (heatmap)",
   "enforce": "REQUIRE reorder rows/cols (AP5) + cap outliers ~95pct (AP6)",
   "ref": "AP5/AP6"
  },
  {
   "id": "R-bar-meadow",
   "when": "many bars across a factor",
   "enforce": "facet/small-multiples (M7) instead of a bar meadow",
   "ref": "AP4"
  },
  {
   "id": "R-zerobase",
   "when": "bar chart",
   "enforce": "bars zero-based, no broken axis (length encodes value)",
   "ref": "AP9"
  },
  {
   "id": "R-PK",
   "when": "domain~PK & intent~exposure/compare",
   "enforce": "REJECT mean\u00b1SD-linear + t-test; geometric mean, log, 90% CI (S30/S25)",
   "ref": "DS5"
  },
  {
   "id": "R-dissolution",
   "when": "domain~dissolution",
   "enforce": "profile (S29) + f2/bootstrap-f2/Mahalanobis + %RSD; not a single-endpoint bar + ANOVA",
   "ref": "DS5"
  },
  {
   "id": "R-modelval",
   "when": "domain in CFD/PINN/IVIVC & intent~agreement/validation",
   "enforce": "REQUIRE parity (S13) + Bland-Altman/%PE/GCI/relative-L2 (S14/S20)",
   "ref": "DS5, M9"
  },
  {
   "id": "R-palette",
   "when": "a journal palette is requested but colorblind_safe==false",
   "enforce": "WARN; keep okabe_ito default OR add redundant encoding (position+direct label+marker/shape)",
   "ref": "AP12, pub-ready R4/R5"
  }
 ]
}