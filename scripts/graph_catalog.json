   "prefer_palette": "viridis",
   "ref": "10.1038/nmeth.1618"
  },
  {
   "id": "AP13",
   "name": "Stacked bar without reordering segments",
   "fix": "order stack segments meaningfully",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP14",
   "name": "Mixing stacked bars with mean separation",
   "fix": "don't combine proportion-stacking with mean\u00b1error",
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP15",
   "name": "Histogram for small n",
   "fix": "use dot/strip",
   "prefer": [
    "S2"
   ],
   "ref": "FriendsDontLetFriends"
  },
  {
   "id": "AP16",
   "name": "Boxplot for bimodal data",
   "fix": "show the distribution (raincloud/histogram/violin at large n)",
   "ref": "FriendsDontLetFriends"
  }
 ],
